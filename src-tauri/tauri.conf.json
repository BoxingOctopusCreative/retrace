{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "retrace",
  "version": "0.3.2",
  "identifier": "com.boxingoctopus.retrace",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Re:Trace",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1M0QyMTBERjFCM0I5OUMKUldTY3ViUHhEU0U5ZGJZYVU5RjVqOVo0UTROaXBLSDlKUFhzYjVKdFNkY0FVN3ZkUG5KUXpDRkMK",
      "endpoints": [
        "https://github.com/BoxingOctopusCreative/retrace/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/uv"
    ],
    "resources": {
      "resources/sidecar.py": "sidecar.py",
      "resources/requirements.txt": "requirements.txt"
    }
  }
}
